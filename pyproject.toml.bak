[build-system]
requires = ["setuptools>=68", "wheel"]
build-backend = "setuptools.build_meta"

[project]
name = "ragdx"
version = "0.3.0"
description = "RAG evaluation, diagnosis, and optimization workbench integrating Ragas, RAGChecker, DSPy, and AutoRAG"
readme = "README.md"
requires-python = ">=3.10"
authors = [{name = "OpenAI"}]
dependencies = [
  "pydantic>=2.7",
  "pandas>=2.2",
  "numpy>=1.26",
  "pyyaml>=6.0",
  "plotly>=5.22",
  "streamlit>=1.35",
  "typer>=0.12",
  "rich>=13.7"
]

[project.optional-dependencies]
ragas = ["ragas>=0.3"]
ragchecker = ["ragchecker>=0.1"]
dspy = ["dspy>=2.6"]
autorag = ["AutoRAG>=0.3"]
openai = ["openai>=1.30"]
all = [
  "ragas>=0.3",
  "ragchecker>=0.1",
  "dspy>=2.6",
  "AutoRAG>=0.3",
  "openai>=1.30"
]

[project.scripts]
ragdx-dashboard = "ragdx.ui.dashboard:main"
ragdx-demo = "ragdx.demo:main"
ragdx = "ragdx.cli:app"

[tool.setuptools]
package-dir = {"" = "src"}

[tool.setuptools.packages.find]
where = ["src"]
